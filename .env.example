# ─────────────────────────────────────────────────────────────────────────────
# SafariCharge Dashboard - Environment Variables
# Copy this file to ".env" and fill in the values before starting the server.
# NEVER commit the actual ".env" file to source control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database (required) ───────────────────────────────────────────────────────
# Path to the SQLite file used by Prisma.
# Change to a PostgreSQL / MySQL connection string for production.
DATABASE_URL="file:./dev.db"

# ── Google Gemini AI (optional but recommended) ───────────────────────────────
# The SafariCharge AI assistant tries Gemini first and falls back to the
# built-in Z.AI SDK when this key is absent or all Gemini models fail.
#
# How to obtain a key:
#   1. Go to https://aistudio.google.com/apikey
#   2. Click "Create API Key" and copy the generated key.
#   3. Paste it below (remove the leading "#").
#
# The key is used server-side only (in src/app/api/safaricharge-ai/route.ts)
# and is never exposed to the browser.
#
# GEMINI_API_KEY=YOUR_GOOGLE_GEMINI_API_KEY_HERE

# ── Z.AI API (optional fallback) ─────────────────────────────────────────────
# When Gemini is unavailable, the AI assistant falls back to Z.AI using the
# OpenAI-compatible SDK with glm-5-turbo model.
#
# How to obtain a key:
#   1. Sign up at https://z.ai
#   2. Navigate to API keys section
#   3. Create a new API key and copy it
#   4. Paste it below (remove the leading "#").
#
# ZAI_API_KEY=YOUR_ZAI_API_KEY_HERE

# ── API Security (recommended) ───────────────────────────────────────────────
# Shared bearer token for server-to-server calls. Add to Authorization header
# as "Bearer <token>" for protected endpoints (AI, exports, reports).
# API_SERVICE_TOKEN="set-a-strong-random-token"

# Optional HMAC secret to verify incoming POST bodies (X-SC-Signature header).
# WEBHOOK_SECRET="use-32+chars-for-hmac"

# Comma-separated origins allowed to call API routes.
# API_ALLOWED_ORIGINS="https://sc-solar-dashboard.vercel.app,http://localhost:3000"

# Enable role-based access control with the x-sc-role header (viewer/operator/analyst/admin).
# ENABLE_RBAC=true

# Override the default RBAC header name if needed.
# API_ROLE_HEADER="x-sc-role"

# Middleware rate-limit tuning (per sliding window).
# RATE_LIMIT_WINDOW_MS=60000
# RATE_LIMIT_API_PER_WINDOW=60
# RATE_LIMIT_AI_PER_WINDOW=10
# RATE_LIMIT_REPORT_PER_WINDOW=5

# Auth middleware validation cadence (ms).
# Lower = stricter validation; Higher = fewer remote auth checks and faster navigation.
# Recommended: 30000-120000. Default in code is 60000.
# AUTH_VALIDATION_WINDOW_MS=60000

# ── Authentication (required for login) ───────────────────────────────────────
# Public app URL used in auth links (magic link + password reset)
# NEXTAUTH_URL="http://localhost:3000"
#
# Random secret for NextAuth session/jwt encryption (use >= 32 chars).
# Generate 32 random bytes with: openssl rand -base64 32 (outputs ~43 chars)
# NEXTAUTH_SECRET="replace-with-a-strong-random-secret"
#
# Resend API key used for magic-link and password-reset emails
# RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxx"
#
# Verified sender identity in Resend
# EMAIL_FROM="SafariCharge <noreply@safaricharge.ke>"

# Supabase browser auth
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""

# ── Next.js (optional) ───────────────────────────────────────────────────────
# Uncomment to override the default Next.js telemetry / analytics settings.
# NEXT_TELEMETRY_DISABLED=1
