# ───────────────────────────────────────────────────────────────────────────
# SafariCharge — Environment Variables
# Copy to .env and fill in values. NEVER commit the real .env.
# ───────────────────────────────────────────────────────────────────────────

# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://safaricharge:safaricharge_dev@localhost:5432/safaricharge"
# For local SQLite dev (no Postgres needed):
# DATABASE_URL="file:./dev.db"

# PostgreSQL credentials (used by docker-compose)
POSTGRES_USER=safaricharge
POSTGRES_PASSWORD=safaricharge_dev
POSTGRES_DB=safaricharge

# ── App URL ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Google Gemini AI (optional) ───────────────────────────────────────────────
# GEMINI_API_KEY=YOUR_GOOGLE_GEMINI_API_KEY_HERE

# ── Z.AI API (optional fallback) ──────────────────────────────────────────────
# ZAI_API_KEY=YOUR_ZAI_API_KEY_HERE

# ── API security ─────────────────────────────────────────────────────────────
# Shared bearer token for the IoT bridge → /api/ingest and other server-to-server calls.
# Generate with: openssl rand -hex 32
# API_SERVICE_TOKEN="set-a-strong-random-token-here"
# WEBHOOK_SECRET="use-32+chars-for-hmac"
# API_ALLOWED_ORIGINS="https://your-domain.com,http://localhost:3000"
# ENABLE_RBAC=true

# ── IoT bridge (iot-bridge service) ────────────────────────────────────────────
# MQTT broker
# MQTT_BROKER_URL=mqtt://192.168.1.100:1883
# MQTT_TOPIC_PREFIX=safaricharge/
# MQTT_USERNAME=
# MQTT_PASSWORD=
#
# Modbus TCP (leave blank to disable)
# MODBUS_HOST=192.168.1.101
# MODBUS_PORT=502
# MODBUS_UNIT_ID=1
# MODBUS_POLL_MS=5000
#
# Logical site ID included with every reading
# SITE_ID=nairobi-site-01

# ── VPS deploy (GitHub Actions → .github/workflows/deploy.yml) ────────────────
# Set these as GitHub repository secrets, NOT in this file:
#   VPS_HOST      – IP or domain of your VPS
#   VPS_USER      – SSH user (e.g. ubuntu)
#   VPS_SSH_KEY   – contents of your private SSH key
#   VPS_PORT      – SSH port (default 22)

# ── Rate limiting (optional) ───────────────────────────────────────────────────
# RATE_LIMIT_WINDOW_MS=60000
# RATE_LIMIT_API_PER_WINDOW=60
# RATE_LIMIT_AI_PER_WINDOW=10
# RATE_LIMIT_REPORT_PER_WINDOW=5

# ── Next.js ───────────────────────────────────────────────────────────────────
# NEXT_TELEMETRY_DISABLED=1
