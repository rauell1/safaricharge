#!/usr/bin/env bash
# .githooks/pre-commit
# --------------------
# Performs change detection, hotspot tracking, and risk flagging
# BEFORE a commit is recorded.
#
# INSTALL:
#   git config core.hooksPath .githooks
#
# What it does:
#   1. Identifies staged files and classifies their risk level
#   2. Warns if a critical/high-risk file is being modified
#   3. Updates hotspot frequency tracking in docs/.map-hotspots.json
#   4. Blocks commits that touch too many critical files at once (optional)

set -e

REPO_ROOT="$(git rev-parse --show-toplevel)"
HOTSPOTS_FILE="$REPO_ROOT/docs/.map-hotspots.json"
WARN_THRESHOLD=3   # Warn if >= 3 critical files staged

# ---------------------------------------------------------------------------
# Risk classification (mirrors scripts/generate-codebase-map.js rules)
# ---------------------------------------------------------------------------
classify_risk() {
  local file="$1"
  case "$file" in
    src/app/page.tsx)                              echo "critical" ;;
    src/app/api/safaricharge-ai/*)                echo "critical" ;;
    src/middleware.ts)                             echo "critical" ;;
    src/lib/config.ts)                             echo "critical" ;;
    src/simulation/runSimulation.ts)               echo "critical" ;;
    src/lib/physics-engine.ts)                     echo "high" ;;
    src/lib/recommendation-engine.ts)              echo "high" ;;
    src/lib/financial-dashboard.ts)                echo "high" ;;
    src/lib/tariff.ts)                             echo "high" ;;
    src/lib/nasa-power-api.ts)                     echo "high" ;;
    src/simulation/*)                              echo "high" ;;
    src/hooks/useEnergySystem.ts)                  echo "high" ;;
    src/components/RecommendationComponents.tsx)   echo "high" ;;
    src/middleware.ts)                             echo "high" ;;
    src/components/dashboard/*)                   echo "medium" ;;
    src/lib/*)                                    echo "medium" ;;
    src/components/ui/*)                          echo "low" ;;
    *)                                            echo "low" ;;
  esac
}

# ---------------------------------------------------------------------------
# Get staged source files
# ---------------------------------------------------------------------------
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACDMR | grep -E '\.(ts|tsx|js|mjs)$' || true)

if [ -z "$STAGED_FILES" ]; then
  exit 0
fi

# ---------------------------------------------------------------------------
# Classify and count risk levels
# ---------------------------------------------------------------------------
CRITICAL_FILES=()
HIGH_FILES=()

while IFS= read -r file; do
  risk=$(classify_risk "$file")
  case "$risk" in
    critical) CRITICAL_FILES+=("$file") ;;
    high)     HIGH_FILES+=("$file") ;;
  esac
done <<< "$STAGED_FILES"

CRITICAL_COUNT=${#CRITICAL_FILES[@]}
HIGH_COUNT=${#HIGH_FILES[@]}

# ---------------------------------------------------------------------------
# Risk warnings
# ---------------------------------------------------------------------------
if [ "$CRITICAL_COUNT" -gt 0 ]; then
  echo ""
  echo "┌─────────────────────────────────────────────────────────┐"
  echo "│  ⚠️  CRITICAL FILES STAGED                               │"
  echo "│  These files are high-risk core modules:                │"
  for f in "${CRITICAL_FILES[@]}"; do
    printf "│    🔴 %-53s│\n" "$f"
  done
  echo "│                                                         │"
  echo "│  Review your changes carefully before committing.       │"
  echo "└─────────────────────────────────────────────────────────┘"
  echo ""
fi

if [ "$HIGH_COUNT" -gt 0 ]; then
  echo "  🟠 High-risk files staged (${HIGH_COUNT}):"
  for f in "${HIGH_FILES[@]}"; do
    echo "    - $f"
  done
  echo ""
fi

# Block if too many critical files changed at once (configurable gate)
if [ "$CRITICAL_COUNT" -ge "$WARN_THRESHOLD" ]; then
  echo "❌ PRE-COMMIT BLOCKED: ${CRITICAL_COUNT} critical files staged at once (threshold: ${WARN_THRESHOLD})"
  echo "   Please split this change into smaller, targeted commits."
  echo "   To override: git commit --no-verify"
  exit 1
fi

# ---------------------------------------------------------------------------
# Update hotspot frequency tracking
# ---------------------------------------------------------------------------
if command -v node >/dev/null 2>&1; then
  node -e "
const fs = require('fs');
const path = require('path');
const file = '${HOTSPOTS_FILE}';
let data = {};
try { data = JSON.parse(fs.readFileSync(file, 'utf8')); } catch {}
const staged = \`${STAGED_FILES}\`.split('\n').filter(Boolean);
for (const f of staged) {
  if (!data[f]) data[f] = { commitCount: 0, lastModified: null };
  data[f].commitCount++;
  data[f].lastModified = new Date().toISOString();
}
// Sort by commit count descending
const sorted = Object.fromEntries(
  Object.entries(data).sort((a, b) => b[1].commitCount - a[1].commitCount)
);
fs.mkdirSync(path.dirname(file), { recursive: true });
fs.writeFileSync(file, JSON.stringify(sorted, null, 2));
" 2>/dev/null || true

  # Stage the updated hotspot tracking file
  git add "$HOTSPOTS_FILE" 2>/dev/null || true
fi

exit 0
